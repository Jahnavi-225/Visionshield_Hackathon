rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'displayName', 'monitoringEnabled', 'monitoredPlatforms', 'createdAt'])
          && data.uid == request.auth.uid
          && data.email is string && data.email.size() <= 256
          && data.displayName is string && data.displayName.size() <= 128
          && data.monitoringEnabled is bool
          && data.monitoredPlatforms is list
          && (data.get('socialHandles', null) == null || data.socialHandles is map)
          && (data.get('openNetworks', null) == null || data.openNetworks is list)
          && data.createdAt is string;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'monitoringEnabled', 'monitoredPlatforms', 'socialHandles']);
    }

    // Report Rules
    match /reports/{reportId} {
      function isValidReport(data) {
        return data.keys().hasAll(['userId', 'type', 'source', 'isAiGenerated', 'confidenceScore', 'riskLevel', 'analysis', 'createdAt'])
          && data.userId == request.auth.uid
          && data.type in ['url', 'image', 'video', 'post']
          && data.source is string && data.source.size() <= 2048
          && data.isAiGenerated is bool
          && data.confidenceScore is number
          && data.riskLevel in ['low', 'medium', 'high', 'critical']
          && data.analysis is string && data.analysis.size() <= 5000
          && data.createdAt is string;
      }

      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidReport(incoming()) && isValidId(reportId);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
