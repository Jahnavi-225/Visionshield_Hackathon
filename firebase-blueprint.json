{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings for monitoring digital health.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "monitoringEnabled": { "type": "boolean" },
        "monitoredPlatforms": { 
          "type": "array",
          "items": { "type": "string", "enum": ["instagram", "google", "youtube", "twitter"] }
        },
        "socialHandles": {
          "type": "object",
          "properties": {
            "instagram": { "type": "string" },
            "twitter": { "type": "string" },
            "youtube": { "type": "string" },
            "google": { "type": "string" }
          }
        },
        "openNetworks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Report": {
      "title": "Analytic Report",
      "description": "A report generated by classifying a post, profile, or file.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["url", "image", "video", "post"] },
        "source": { "type": "string" },
        "isAiGenerated": { "type": "boolean" },
        "confidenceScore": { "type": "number" },
        "riskLevel": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "analysis": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "isAiGenerated"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Classification reports"
    }
  }
}
